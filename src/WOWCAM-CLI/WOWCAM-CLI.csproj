<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework Condition="'$([MSBuild]::IsOSPlatform(`Windows`))' == 'true'">net48</TargetFramework>
    <TargetFramework Condition="'$([MSBuild]::IsOSPlatform(`OSX`))' == 'true'">net10.0</TargetFramework>
    <LangVersion>12.0</LangVersion>
    <RootNamespace>WOWCAM_CLI</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <!-- For Windows 10/11 (targetting .NET Framework 4.8 which is always present there by default) -->
    <Reference Include="System.Net.Http" />
    <Using Include="System.Net.Http" />
  </ItemGroup>

  <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <!-- For macOS (targetting .NET 10 as self-contained binary on Apple silicon) -->
    <RuntimeIdentifier>osx-arm64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>true</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>

</Project>